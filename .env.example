# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Database backend — choose one:
# ---------------------------------------------------------------------------

# Option A: Firebase (default)
# Leave VITE_DB_BACKEND unset or set to "firebase"
# VITE_DB_BACKEND=firebase

# Option B: Firebase Emulators (local dev, no cloud)
# Run:  npx firebase emulators:start
# Then set:
# VITE_USE_EMULATORS=true
# VITE_DB_BACKEND=firebase

# Option C: PocketBase (fully self-hosted, runs on your PC)
# 1. Download PocketBase: https://pocketbase.io/docs/
# 2. Run:  ./pocketbase serve
# 3. Create admin at http://localhost:8090/_/
# 4. Run:  node scripts/setup-pocketbase.js
# 5. Set:
VITE_DB_BACKEND=pocketbase
VITE_PB_URL=http://localhost:8090
#
# For Android testing (phone + PC on same Wi-Fi):
# Find your PC's LAN IP (e.g. 192.168.1.42) and use:
# VITE_PB_URL=http://192.168.1.42:8090

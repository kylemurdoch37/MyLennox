# =============================================================================
# MyLennox — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Gemini AI (chatbot feature)
# Get your key at: https://aistudio.google.com/app/apikey
# Note: no VITE_ prefix — loaded via vite.config.ts defineConfig
# ---------------------------------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key_here"

# ---------------------------------------------------------------------------
# Database backend — choose ONE of the options below:
# ---------------------------------------------------------------------------

# Option A: Firebase (default — cloud hosted)
# Leave VITE_DB_BACKEND unset or set to "firebase"
# Requires a Firebase project with Firestore + Authentication enabled.
# VITE_DB_BACKEND=firebase

# Option B: Firebase Emulators (local dev, no cloud charges)
# 1. Install Firebase CLI:  npm install -g firebase-tools
# 2. Run:                   npm run emulators
# 3. Set:
# VITE_USE_EMULATORS=true
# VITE_DB_BACKEND=firebase

# Option C: PocketBase (fully self-hosted, free, runs on your PC)
# 1. Download PocketBase:   https://pocketbase.io/docs/
# 2. Run:                   ./pocketbase serve
# 3. Create admin at:       http://localhost:8090/_/
# 4. Set up main app:       node scripts/setup-pocketbase.js
# 5. Set up staff portal:   node staff-portal/scripts/setup-pocketbase.js
# 6. Set:
VITE_DB_BACKEND=pocketbase
VITE_PB_URL=http://localhost:8090
#
# For Android/iOS testing (phone + PC on same Wi-Fi):
# Replace with your PC's LAN IP, e.g.:
# VITE_PB_URL=http://192.168.1.42:8090

# ---------------------------------------------------------------------------
# Staff Portal (staff-portal/)
# Runs on port 4000. Uses the SAME PocketBase instance as the main app.
# No extra env vars needed — staff-portal reads VITE_PB_URL from its own
# .env (or inherits from the shell environment).
#
# To set up staff portal collections + seed demo staff accounts:
#   node staff-portal/scripts/setup-pocketbase.js
#
# Default logins (password: LennoxGov2026!):
#   admin@lennox.gov            → admin, all agencies
#   lhdb.manager@lennox.gov     → manager, Housing
#   lhdb.staff@lennox.gov       → staff, Housing
#   marine.manager@lennox.gov   → manager, Marine
#   metro.manager@lennox.gov    → manager, Metro
#   lhs.manager@lennox.gov      → manager, Health
# ---------------------------------------------------------------------------

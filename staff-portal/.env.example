# =============================================================================
# Lennox Government Staff Portal — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# PocketBase URL (must match the main app's PocketBase instance)
VITE_PB_URL=http://localhost:8090

# For Android/iOS staff devices on the same network as your PC:
# VITE_PB_URL=http://192.168.1.42:8090
